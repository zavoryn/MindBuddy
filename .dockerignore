# =============================================================================
# MiniCode Python — Docker ignore
# =============================================================================

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Test and dev files
tests/
benchmarks/
docs/
*.md
!README.md

# IDE and editor
.vscode/
.idea/
*.swp
*.swo

# Environment (never include secrets in image)
.env
.env.*

# Session / log / temp data
session-log.txt
*.log
*.tmp

# Git
.git/
.gitignore

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Agent tooling
.claude/
CLAUDE.md
.mewcode/
.mindbuddy/

# Local config
config.yaml
*.local.yaml

# Virtual environments
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db
